              "widgetType": "text-editor"
            },
            {
              "id": "about-title",
              "elType": "widget",
              "settings": {
                "editor": "Hands-On Readiness Support, Together",
                "heading_title": "h2",
                "title_color": "#0b2545",
                "typography_font_family": "Montserrat",
                "typography_font_size": {"unit": "px", "size": 36},
                "typography_font_weight": "700",
                "margin": {"unit": "px", "bottom": 16}
              },
              "widgetType": "heading"
            },
            {
              "id": "about-para1",
              "elType": "widget",
              "settings": {
                "text": "The South Florida Personal Narrative Readiness Summit is a facilitator-led, hands-on working event designed to help DBE and ACDBE business owners develop their Personal Narrative, organize supporting information, and improve reevaluation submission readiness through practical, structured guidance.",
                "text_color": "#475569",
                "typography_font_size": {"unit": "px", "size": 15.5},
                "line_height": "1.75",
                "margin": {"unit": "px", "bottom": 16}
              },
              "widgetType": "text-editor"
            },
            {
              "id": "about-para2",
              "elType": "widget",
              "settings": {
                "text": "Unlike a traditional seminar or webinar, this is a working session. Participants will leave with a clearer narrative, organized supporting facts, and greater confidence about their reevaluation submission — not just a better understanding of the process.",
                "text_color": "#475569",
                "typography_font_size": {"unit": "px", "size": 15.5},
                "line_height": "1.75",
                "margin": {"unit": "px", "bottom": 16}
              },
              "widgetType": "text-editor"
            },
            {
              "id": "about-para3",
              "elType": "widget",
              "settings": {
                "text": "GHN Communications brings the same one-on-one strategic guidance methodology used in individualized sessions into a small-group format — maximizing both the depth of support and the breadth of peer learning.",
                "text_color": "#475569",
                "typography_font_size": {"unit": "px", "size": 15.5},
                "line_height": "1.75"
              },
              "widgetType": "text-editor"
            }
          ]
        },
