            },
            {
              "id": "session-block-1",
              "elType": "widget",
              "settings": {
                "text": "<div style=\"background:#f8fafc; border:1px solid #e2e8f0; border-radius:10px; padding:22.4px; margin-bottom:13.6px; border-left:4px solid #c8922a;\"><div style=\"font-family:Montserrat; font-size:10.4px; font-weight:700; color:#c8922a; text-transform:uppercase; letter-spacing:2.4px; margin-bottom:4.8px;\">Working Session 1</div><h4 style=\"font-size:15.2px; color:#0b2545; margin-bottom:4.8px; font-family:Montserrat; font-weight:700;\">Narrative Foundation &amp; Qualifying Event Development</h4><p style=\"font-size:13.3px; color:#475569; line-height:1.6; margin:0;\">Guided small-group work to identify and structure the qualifying event, clarify the personal impediment, and establish the narrative foundation for your Personal Narrative.</p></div>"
              },
              "widgetType": "text-editor"
            },
            {
              "id": "session-block-2",
              "elType": "widget",
              "settings": {
                "text": "<div style=\"background:#f8fafc; border:1px solid #e2e8f0; border-radius:10px; padding:22.4px; border-left:4px solid #c8922a;\"><div style=\"font-family:Montserrat; font-size:10.4px; font-weight:700; color:#c8922a; text-transform:uppercase; letter-spacing:2.4px; margin-bottom:4.8px;\">Working Session 2</div><h4 style=\"font-size:15.2px; color:#0b2545; margin-bottom:4.8px; font-family:Montserrat; font-weight:700;\">Economic Impact &amp; Submission Readiness Review</h4><p style=\"font-size:13.3px; color:#475569; line-height:1.6; margin:0;\">Deep dive into articulating the resulting economic impact, strengthening narrative clarity, and preparing your draft for submission — with direct facilitator feedback.</p></div>"
